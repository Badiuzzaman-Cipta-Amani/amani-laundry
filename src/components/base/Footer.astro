---
import { socialMedia, links, branches, commonWords } from "@/data/common.json";
import { Facebook, Instagram, Tiktok, Whatsapp } from "simple-icons-astro";
import { Mail } from "@lucide/astro";
import { formatPhoneNumber } from "@/utils/number";
---

<footer class="bg-amani-blue-dark text-white pt-20 pb-10 px-6">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-10">
    <div class="lg:col-span-1">
      <img src="/logo.svg" alt="Logo Amani Laundry" class="w-26 mb-4" />
      <h3 class="text-2xl font-extrabold mb-4 flex items-center gap-3">
        Amani Laundry
      </h3>
      <p class="text-white/70 text-sm leading-relaxed mb-5">
        {commonWords.description}
      </p>
      <nav class="flex gap-3">
        <a
          href={socialMedia.facebook}
          class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-white hover:bg-amani-yellow hover:text-amani-blue-dark transition-all no-underline"
        >
          <Facebook />
        </a>
        <a
          href={socialMedia.instagram}
          class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-white hover:bg-amani-yellow hover:text-amani-blue-dark transition-all no-underline"
        >
          <Instagram />
        </a>
        <a
          href={socialMedia.tiktok}
          class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center text-white hover:bg-amani-yellow hover:text-amani-blue-dark transition-all no-underline"
        >
          <Tiktok />
        </a>
      </nav>
    </div>
    <nav>
      <h4 class="text-base font-bold mb-5 text-amani-yellow">Menu</h4>
      {
        links.map((v) => (
          <a
            href={v.url}
            class="block text-white/70 text-sm mb-3 hover:text-white transition-colors no-underline"
          >
            {v.label}
          </a>
        ))
      }
    </nav>
    <div>
      <h4 class="text-base font-bold mb-5 text-amani-yellow">Kontak</h4>
      <nav class="space-y-3">
        <a
          href={`mailto:${socialMedia.email}`}
          class="flex items-center gap-3 text-white/70 hover:text-white text-sm transition-colors no-underline"
        >
          <span
            class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-sm shrink-0"
          >
            <Mail class="size-4" />
          </span>
          <span>{socialMedia.email}</span>
        </a>
        {
          branches.map((branch) => (
            <a
              href={`https://wa.me/${branch.phone.slice(1)}`}
              target="_blank"
              class="flex items-start gap-3 text-white/70 hover:text-white text-sm"
            >
              <span class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-sm shrink-0">
                <Whatsapp class="size-4" />
              </span>
              <div>
                <p class="text-white font-medium text-sm">{branch.name}</p>
                <p>{formatPhoneNumber(branch.phone)}</p>
              </div>
            </a>
          ))
        }
      </nav>
    </div>
  </div>
  <div
    class="max-w-7xl mx-auto mt-10 pt-6 border-t border-white/10 text-center text-white/50 text-sm"
  >
    © {new Date().getFullYear()} Amani Laundry. Laundry Antar Jemput. All rights reserved.
  </div>
</footer>
