---
interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;
---

<div>
  <nav
    class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-amani-blue/10"
  >
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
      <a href="/" class="py-2">
        <img
          src="/logo.svg"
          alt="Logo Amani Laundry"
          class="w-full h-16"
        />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a
          href="/"
          class={`text-sm font-medium transition-colors no-underline ${
            currentPage === "home"
              ? "text-amani-blue"
              : "text-slate-700 hover:text-amani-blue"
          }`}
        >
          Beranda
        </a>
        <a
          href="/blogs"
          class={`text-sm font-medium transition-colors no-underline ${
            currentPage === "blogs"
              ? "text-amani-blue"
              : "text-slate-700 hover:text-amani-blue"
          }`}
        >
          Blog
        </a>
        <a
          href="/calculator"
          class="bg-amani-blue text-white px-6 py-2.5 rounded-lg text-sm font-semibold hover:bg-amani-blue-dark transition-all no-underline"
          >🧺 Hitung Estimasi Biaya</a
        >
      </div>
      <button
        id="mobileMenuBtn"
        class="md:hidden bg-none border-none text-2xl text-amani-blue cursor-pointer"
        >☰</button
      >
    </div>
  </nav>
  <div
    id="mobileMenu"
    class="hidden fixed top-18 left-0 right-0 bg-white border-b border-slate-200 p-5 px-6 z-40 shadow-lg"
  >
    <a
      href="/"
      class={`block py-3.5 font-semibold border-b border-slate-100 no-underline transition-colors mt-1 rounded-lg px-3 ${
        currentPage === "home"
          ? "text-amani-blue bg-amani-blue/5"
          : "text-slate-800 hover:text-amani-blue hover:bg-slate-50"
      }`}
    >
      Beranda
    </a>
    <a
      href="/blogs"
      class={`block py-3.5 font-semibold border-b border-slate-100 no-underline transition-colors mt-1 rounded-lg px-3 ${
        currentPage === "blogs"
          ? "text-amani-blue bg-amani-blue/5"
          : "text-slate-800 hover:text-amani-blue hover:bg-slate-50"
      }`}
    >
      Blog
    </a>
    <a
      href="/calculator"
      class={`block py-3.5 font-semibold no-underline transition-colors mt-1 rounded-lg px-3 ${
        currentPage === "calculator"
          ? "text-amani-blue bg-amani-blue/5"
          : "text-slate-800 hover:text-amani-blue hover:bg-slate-50"
      }`}
    >
      Hitung Biaya
    </a>
  </div>
</div>

<script>
  const menuBtn = document.getElementById("mobileMenuBtn");
  const mobileMenu = document.getElementById("mobileMenu");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  const mobileLinks = mobileMenu?.querySelectorAll("a");
  mobileLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
    });
  });
</script>
