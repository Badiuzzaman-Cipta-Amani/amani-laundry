---
import BlogListClient from "@/components/blog/BlogListClient.vue";
import { getCollection } from 'astro:content';

const entries = await getCollection('blogs');

const posts = entries.map((e) => ({
  slug: e.id,
  title: e.data.title,
  excerpt: e.data.excerpt,
  image: e.data.cover,
  category: e.data.category,
  categoryLabel:
    e.data.category === 'tips'
      ? 'Tips'
      : e.data.category === 'promo'
      ? 'Promo'
      : 'Info',
  date: new Date(e.data.date).toLocaleDateString('id-ID', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }),
  year: String(new Date(e.data.date).getFullYear()),
}));
---

<div>
  <BlogListClient client:load posts={posts} />
</div>
