---
import services from "@/data/services.json";
import { ArrowRight } from '@lucide/astro';
---

<section class="py-24 px-6 max-w-7xl mx-auto" id="services">
  <div class="text-center mb-16">
    <div
      class="inline-block bg-amani-blue/8 text-amani-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4"
    >
      Layanan Kami
    </div>
    <h2 class="text-4xl font-extrabold text-slate-800 mb-4">
      Beragam layanan laundry<br />hanya untuk anda
    </h2>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
      Amani Laundry hadir memenuhi semua kebutuhan anda dengan cepat.<br />Satu
      mesin, satu customer!
    </p>
  </div>
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      services.map((service) => (
        <div class="bg-white border border-slate-200 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-2xl hover:shadow-amani-blue/10 hover:border-amani-blue-light transition-all relative overflow-hidden group service-card">
          <div
            class={`w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-5 ${service.bgClass}`}
          >
            {service.icon}
          </div>
          <h3 class="text-lg font-bold text-slate-800 mb-2">{service.name}</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4">
            {service.desc}
          </p>
          <div class="text-lg font-extrabold text-amani-blue">
            {service.price}{" "}
            <span class="text-sm font-medium text-slate-600">
              / {service.unit}
            </span>
          </div>
        </div>
      ))
    }
  </div>
  <div class="text-center mt-12">
    <a
      href="/calculator"
      class="inline-flex items-center gap-2 bg-amani-blue text-white px-8 py-4 rounded-xl font-bold text-base hover:bg-amani-blue-dark transition-all no-underline"
    >
      Lihat Semua Layanan <ArrowRight class="w-4 h-4" />
    </a>
  </div>
</section>
