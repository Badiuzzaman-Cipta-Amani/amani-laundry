---
import MainLayout from "@/layouts/MainLayout.astro";
import Navbar from "@/components/base/Navbar.astro";
import ShareButton from "@/components/blog/ShareButton.vue";
import CopyButton from "@/components/base/button/CopyButton.vue";
import BlogCard from "@/components/blog/BlogCard.vue";
import Footer from "@/components/base/Footer.astro";
import blogPosts from "@/data/blogPosts.json";

export const getStaticPaths = () => {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;

const countWords = () => {
  const text = post.content.replace(/<[^>]*>/g, "");
  return text.trim().split(/\s+/).length;
};

const readingTime = Math.max(1, Math.ceil(countWords() / 200));

const recommendedPosts = (() => {
  return blogPosts.filter((p) => p.id !== post.id).slice(0, 3);
})();
---

<MainLayout
  title={`${post.title}`}
  description={post.excerpt}
  ogImage={post.image}
>
  <Navbar currentPage="blog" />
  <main>
    <div class="h-18"></div>
    <article class="py-24 px-6 max-w-3xl mx-auto">
      <header>
        <div class="text-center mb-10">
          <div class="flex items-center justify-center gap-4 mb-5">
            <div
              class="bg-amani-yellow text-amani-blue-dark px-4 py-1.5 rounded-full text-xs font-bold"
            >
              {post.categoryLabel}
            </div>
            <div class="text-sm text-slate-500">{post.date}</div>
          </div>
          <h1
            class="text-4xl lg:text-5xl font-extrabold text-slate-800 leading-tight mb-4"
          >
            {post.title}
          </h1>
          <div
            class="flex items-center justify-center gap-4 text-sm text-slate-500"
          >
            <span>⏱️ {readingTime} menit baca</span>
          </div>
        </div>
        <div
          class="w-full h-96 rounded-2xl overflow-hidden mb-10 bg-linear-to-br from-indigo-100 to-blue-100"
        >
          <img
            src={post.image}
            alt={post.title}
            class="w-full h-full object-cover"
            onerror="this.style.display='none'; this.parentElement.classList.add('bg-linear-to-br', 'from-indigo-100', 'to-blue-100')"
          />
        </div>
      </header>
      <div class="flex items-center gap-3 mb-10 pb-6 border-b border-slate-200">
        <span class="text-sm text-slate-500 font-medium">Bagikan:</span>
        <ShareButton client:load post={post} />
        <CopyButton client:load copyText={Astro.url.href} />
      </div>
      <div class="blog-content" set:html={post.content} />
    </article>
    <section class="py-16 px-6 bg-slate-50" v-if="post">
      <div class="max-w-7xl mx-auto">
        <h3 class="text-2xl font-bold text-slate-800 mb-6">Artikel Lainnya</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {recommendedPosts.map((rec) => <BlogCard client:load post={rec} />)}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
