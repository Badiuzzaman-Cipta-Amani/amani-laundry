---
import MainLayout from "@/layouts/MainLayout.astro";
import Navbar from "@/components/base/Navbar.astro";
import BlogList from "@/components/blog/BlogList.vue";
import Footer from "@/components/base/Footer.astro";

const title = "Tips & Artikel";
const description =
  "Temukan tips merawat pakaian, informasi layanan, dan promo menarik dari Amani Laundry.";
---

<MainLayout title={title} description={description}>
  <Navbar currentPage="blog" />
  <main>
    <div class="h-18"></div>
    <header class="py-24 px-6 max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <div
          class="inline-block bg-amani-blue/8 text-amani-blue px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4"
        >
          Blog
        </div>
        <h1 class="text-4xl font-extrabold text-slate-800 mb-4">
          {title}
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          {description}
        </p>
      </div>
    </header>
    <section class="py-24 px-6 max-w-7xl mx-auto">
      <BlogList client:load />
    </section>
  </main>
  <Footer />
</MainLayout>
