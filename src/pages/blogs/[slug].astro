---
import MainLayout from "@/layouts/MainLayout.astro";
import Navbar from "@/components/base/Navbar.astro";
import ShareButton from "@/components/blog/ShareButton.vue";
import CopyButton from "@/components/base/button/CopyButton.vue";
import BlogCard from "@/components/blog/BlogCard.vue";
import Footer from "@/components/base/Footer.astro";
import blogPosts from "@/data/blogPosts.json";
import { getCollection } from "astro:content";
import { render } from "astro:content";
import { formatDate } from "@/utils/date";
import { Clock } from '@lucide/astro';
import type { Graph } from 'schema-dts';

export const getStaticPaths = async () => {
  const blogs = await getCollection("blogs");
  return blogs.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
};

const { post } = Astro.props;

const jsonLd = {
 "@context":"https://schema.org",
 "@type":"BlogPosting",
 "headline":post.data.title,
 "description":post.data.excerpt,
 "image":post.data.cover,
 "datePublished":post.data.date,
 "dateModified":post.data.date,
 "author":{
   "@type":"Person",
   "name": post.data.author
 },
 "publisher":{
   "@type":"Organization",
   "name":"Amani Laundry",
   "logo":{
      "@type":"ImageObject",
      "url":Astro.site.host + "/logo.svg",
   }
 }
}

const countWords = () => {
  if (!post.body) return 0;
  const text = post.body.replace(/<[^>]*>/g, "");
  return text.trim().split(/\s+/).length;
};

const readingTime = Math.max(1, Math.ceil(countWords() / 200));

// const recommendedPosts = (() => {
//   return blogPosts.filter((p) => p.id !== post.id).slice(0, 3);
// })();

const { Content } = await render(post);
---

<MainLayout
  title={`${post.data.title}`}
  description={post.data.excerpt}
  ogImage={post.data.cover}
  jsonLd={jsonLd}
>
  <Navbar currentPage="blog" />
  <main>
    <article class="mt-5 py-24 px-6 max-w-3xl mx-auto">
      <header>
        <div class="text-center mb-10">
          <div class="flex items-center justify-center gap-4 mb-5">
            <div
              class="bg-amani-yellow text-amani-blue-dark px-4 py-1.5 rounded-full text-xs font-bold"
            >
              {post.data.category}
            </div>
          </div>
          <h1
            class="text-4xl lg:text-5xl font-extrabold text-slate-800 leading-tight mb-4"
          >
            {post.data.title}
          </h1>
          <div
            class="flex items-center justify-center gap-4 text-sm text-slate-600"
          >
            <span class="flex items-center gap-2"><Clock class="w-4 h-4" /> {readingTime} menit baca</span> | <div
              class="text-sm text-slate-600"
            >
              {formatDate(post.data.date)}
            </div>
          </div>
        </div>
        <div
          class="w-full min-h-96 max-h-96 lg:max-h-150 rounded-2xl overflow-hidden mb-10 bg-linear-to-br from-indigo-100 to-blue-100"
        >
          <img
            src={post.data.cover}
            alt={post.data.title}
            class="w-full h-full object-cover"
            onerror="this.style.display='none'; this.parentElement.classList.add('bg-linear-to-br', 'from-indigo-100', 'to-blue-100')"
          />
        </div>
      </header>
      <div class="flex items-center gap-3 mb-10 pb-6 border-b border-slate-200">
        <span class="text-sm text-slate-600 font-medium">Bagikan:</span>
        <ShareButton client:load post={post} />
        <CopyButton client:load copyText={Astro.url.href} />
      </div>
      <div class="blog-content">
        <Content />
      </div>
    </article>
    <!-- <section class="py-16 px-6 bg-slate-50" v-if="post">
      <div class="max-w-7xl mx-auto">
        <h3 class="text-2xl font-bold text-slate-800 mb-6">Artikel Lainnya</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {recommendedPosts.map((rec) => <BlogCard client:load post={rec} />)}
        </div>
      </div>
    </section> -->
  </main>
  <Footer />
</MainLayout>
