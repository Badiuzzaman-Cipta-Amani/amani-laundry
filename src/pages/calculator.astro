---
import MainLayout from "@/layouts/MainLayout.astro";
import Navbar from "@/components/base/Navbar.astro";
import CategoryTabs from "@/components/calculator/CategoryTabs.vue";
import ServiceGrid from "@/components/calculator/ServiceGrid.vue";
import CartSidebar from "@/components/calculator/CartSidebar.vue";
import MobileCart from "@/components/calculator/MobileCart.vue";
import BranchModal from "@/components/calculator/BranchModal.vue";
import Footer from "@/components/base/Footer.astro";

const title = "Hitung Estimasi Biaya Laundry"
const description = "Pilih layanan yang kamu inginkan, tentukan jumlahnya, dan langsung dapatkan estimasi harga total Anda."
---

<MainLayout title={title} description={description}>
  <Navbar currentPage="calculator" />
  <main>
    <div class="h-18"></div>
    <header
      class="bg-linear-to-br from-amani-blue-dark via-amani-blue to-blue-700 relative overflow-hidden"
    >
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
      >
      </div>
      <div class="max-w-7xl mx-auto px-6 py-16 text-center relative z-10">
        <h1
          class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight mb-4"
        >
          Hitung Estimasi<br />
          <span class="text-amani-yellow"> Biaya Laundry </span>
        </h1>
        <p
          class="text-base sm:text-lg text-white/80 leading-relaxed max-w-2xl mx-auto"
        >
          {description}
        </p>
      </div>
    </header>

    <section class="py-10 px-6 max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-[1fr_440px] gap-8">
        <div>
          <CategoryTabs client:load />
          <ServiceGrid client:visible />
        </div>
        <CartSidebar client:load />
      </div>
    </section>
  </main>
  <MobileCart client:load />
  <BranchModal client:load />
  <Footer />
</MainLayout>
