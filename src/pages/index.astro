---
import MainLayout from '@/layouts/MainLayout.astro';
import Navbar from '@/components/base/Navbar.vue';
import HeroSection from '@/components/home/HeroSection.vue';
import ServicesSection from '@/components/home/ServicesSection.vue';
import AboutSection from '@/components/home/AboutSection.vue';
import BranchesSection from '@/components/home/BranchesSection.vue';
import TestimonialsSection from '@/components/home/TestimonialsSection.vue';
import InstagramCarousel from '@/components/home/InstagramCarousel.vue';
import CTASection from '@/components/home/CTASection.vue';
import Footer from '@/components/base/Footer.vue';
import WhatsAppFloat from '@/components/base/WhatsAppFloat.vue';
---

<MainLayout title="Amani Laundry - Laundry Antar Jemput">
  <Navbar currentPage="home" client:load />
  <main>
    <HeroSection client:load />
    <ServicesSection client:visible />
    <AboutSection client:visible />
    <BranchesSection client:visible />
    <TestimonialsSection client:visible />
    <InstagramCarousel client:visible />
    <CTASection client:visible />
  </main>
  <Footer client:visible />
  <WhatsAppFloat client:load />
</MainLayout>
